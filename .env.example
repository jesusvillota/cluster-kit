# ============================================================================
# Cluster Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with CLUSTER_ for clarity.
#
# Multi-cluster support: prefix with environment name (e.g., CLUSTER_DEV_HOST)
# and set CLUSTER_ENV=dev to select that profile.
# ============================================================================

# ----------------------------------------------------------------------------
# Core Settings (required for single-cluster setup)
# ----------------------------------------------------------------------------

# SSH alias or hostname for the cluster
# Default: cluster
# Validation: Non-empty string, resolvable via DNS or in ~/.ssh/config
CLUSTER_HOST=cluster

# Username on the remote cluster
# Default: current local user (os.getenv('USER'))
# Validation: Non-empty string, must exist on remote cluster
CLUSTER_USER=j-vill36

# Absolute path to the project root on the cluster
# Required: Yes (no default)
# Validation: Must start with /
CLUSTER_REMOTE_BASE=/mnt/slurm-beegfs/Users/j-vill36/scripts_whales

# Path to SSH private key for cluster authentication
# Default: ~/.ssh/id_ed25519_cluster
# Validation: File must exist with permissions 600 or 400
CLUSTER_SSH_KEY=~/.ssh/id_ed25519_cluster

# SSH connection timeout in seconds
# Default: 30
# Validation: Integer between 1 and 300
CLUSTER_SSH_TIMEOUT=30

# Comma-separated rsync exclude patterns (no spaces around commas)
# Default: __pycache__,*.pyc,*.pyo
# Validation: Valid rsync patterns
CLUSTER_SYNC_EXCLUDE=__pycache__,*.pyc,*.pyo

# ----------------------------------------------------------------------------
# Multi-Cluster Profiles (optional)
# ----------------------------------------------------------------------------
# Set CLUSTER_ENV to select which profile to use:
#   export CLUSTER_ENV=dev    → uses CLUSTER_DEV_* variables
#   export CLUSTER_ENV=prod   → uses CLUSTER_PROD_* variables
#   unset CLUSTER_ENV         → uses unprefixed CLUSTER_* variables above
# ----------------------------------------------------------------------------

# --- Development Cluster ---
# CLUSTER_DEV_HOST=dev-cluster
# CLUSTER_DEV_USER=devuser
# CLUSTER_DEV_REMOTE_BASE=/home/devuser/project
# CLUSTER_DEV_SSH_KEY=~/.ssh/dev_cluster_key
# CLUSTER_DEV_SSH_TIMEOUT=15
# CLUSTER_DEV_SYNC_EXCLUDE=__pycache__,*.pyc,*.pyo,.git

# --- Production Cluster ---
# CLUSTER_PROD_HOST=HPCOM-00
# CLUSTER_PROD_USER=j-vill36
# CLUSTER_PROD_REMOTE_BASE=/mnt/slurm-beegfs/Users/j-vill36/scripts_whales
# CLUSTER_PROD_SSH_KEY=~/.ssh/id_ed25519_cluster
# CLUSTER_PROD_SSH_TIMEOUT=30
# CLUSTER_PROD_SYNC_EXCLUDE=__pycache__,*.pyc,*.pyo

# --- Staging Cluster ---
# CLUSTER_STAGING_HOST=staging-cluster
# CLUSTER_STAGING_USER=staging-user
# CLUSTER_STAGING_REMOTE_BASE=/opt/project/staging
# CLUSTER_STAGING_SSH_KEY=~/.ssh/staging_key
# CLUSTER_STAGING_SSH_TIMEOUT=20
# CLUSTER_STAGING_SYNC_EXCLUDE=__pycache__,*.pyc,*.pyo,.git,node_modules
